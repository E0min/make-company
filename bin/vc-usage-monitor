#!/usr/bin/env bash
# vc-usage-monitor — 에이전트별 CTX + 리소스 실시간 모니터
# tmux Usage 윈도우에서 실행됨. 3초마다 갱신.

SESSION="${1:-$(tmux display-message -p '#{session_name}' 2>/dev/null)}"
CLEAR='\033[2J\033[H'
BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[32m'
YELLOW='\033[33m'
CYAN='\033[36m'
RED='\033[31m'
MAGENTA='\033[35m'
RESET='\033[0m'

while true; do
  printf "$CLEAR"
  echo ""
  printf "  ${BOLD}📊 Usage Monitor${RESET}  ${DIM}$(date '+%H:%M:%S')${RESET}\n"
  echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # ── 시스템 리소스 ──
  CPU_LOAD=$(sysctl -n vm.loadavg 2>/dev/null | awk '{gsub(/[{}]/,""); print $1}')
  CPU_CORES=$(sysctl -n hw.ncpu 2>/dev/null || echo "?")
  MEM_TOTAL=$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%.0f", $1/1024/1024/1024}')
  MEM_USED=$(vm_stat 2>/dev/null | awk '
    /Pages active/ {a=$3}
    /Pages wired/ {w=$4}
    /Pages speculative/ {s=$3}
    END {gsub(/\./,"",a); gsub(/\./,"",w); gsub(/\./,"",s); printf "%.1f", (a+w+s)*4096/1024/1024/1024}
  ')

  printf "  ${BOLD}System${RESET}  CPU ${CYAN}${CPU_LOAD}${RESET}/${CPU_CORES}cores  MEM ${CYAN}${MEM_USED:-?}${RESET}/${MEM_TOTAL}GB\n"
  echo ""

  # ── 에이전트별 CTX + 리소스 ──
  printf "  ${BOLD}Agents${RESET}\n"
  printf "    ${DIM}%-16s %6s  %-24s %6s %8s${RESET}\n" "AGENT" "CTX" "CONTEXT BAR" "CPU%" "MEM"
  echo "    ─────────────────────────────────────────────────────────────"

  # tmux 윈도우에서 ctx% 추출 + ps에서 리소스
  tmux list-windows -t "$SESSION" -F '#{window_index} #{window_name}' 2>/dev/null | while read idx name; do
    # Monitor, Usage 윈도우 스킵
    case "$name" in Monitor|Usage) continue ;; esac

    # ctx% 추출 (tmux 스크롤백에서)
    CTX_RAW=$(tmux capture-pane -t "$SESSION:$idx" -p -S - 2>/dev/null | grep -o 'ctx: [0-9]*%' | tail -1)
    CTX_NUM=$(echo "$CTX_RAW" | grep -o '[0-9]*')

    # 에이전트 이름 (claude 윈도우 = CEO)
    case "$name" in
      claude) SHORT="CEO (main)" ;;
      *)      SHORT="$name" ;;
    esac

    # 해당 윈도우의 claude 프로세스 리소스
    # pane PID로 찾기
    PANE_PID=$(tmux list-panes -t "$SESSION:$idx" -F '#{pane_pid}' 2>/dev/null | head -1)
    if [ -n "$PANE_PID" ]; then
      # pane의 자식 프로세스 중 claude 찾기
      CLAUDE_LINE=$(ps -o pid,pcpu,rss,command -p $(pgrep -P "$PANE_PID" 2>/dev/null | tr '\n' ',')0 2>/dev/null | grep "claude" | head -1)
      CPU=$(echo "$CLAUDE_LINE" | awk '{print $2}')
      MEM_KB=$(echo "$CLAUDE_LINE" | awk '{print $3}')
      MEM_MB=$(echo "$MEM_KB" | awk '{printf "%.0f", $1/1024}')
    else
      CPU=""
      MEM_MB=""
    fi

    # CTX 바 그리기 (20칸)
    if [ -n "$CTX_NUM" ]; then
      FILLED=$((CTX_NUM / 5))
      EMPTY=$((20 - FILLED))

      # 색상 결정
      if [ "$CTX_NUM" -ge 60 ]; then
        BAR_COLOR="$RED"
        CTX_COLOR="$RED"
      elif [ "$CTX_NUM" -ge 40 ]; then
        BAR_COLOR="$YELLOW"
        CTX_COLOR="$YELLOW"
      else
        BAR_COLOR="$GREEN"
        CTX_COLOR="$GREEN"
      fi

      BAR="${BAR_COLOR}$(printf '█%.0s' $(seq 1 $FILLED 2>/dev/null) 2>/dev/null)${DIM}$(printf '░%.0s' $(seq 1 $EMPTY 2>/dev/null) 2>/dev/null)${RESET}"
      CTX_STR="${CTX_COLOR}${CTX_NUM}%${RESET}"
    else
      BAR="${DIM}· · · · idle · · · · ·${RESET}"
      CTX_STR="${DIM}--${RESET}"
    fi

    # CPU 색상
    CPU_STR="${DIM}--${RESET}"
    if [ -n "$CPU" ]; then
      CPU_INT=$(echo "$CPU" | awk '{printf "%d", $1}')
      if [ "$CPU_INT" -gt 50 ]; then
        CPU_STR="${RED}${CPU}%${RESET}"
      elif [ "$CPU_INT" -gt 10 ]; then
        CPU_STR="${YELLOW}${CPU}%${RESET}"
      else
        CPU_STR="${GREEN}${CPU}%${RESET}"
      fi
    fi

    MEM_STR="${DIM}--${RESET}"
    [ -n "$MEM_MB" ] && [ "$MEM_MB" != "0" ] && MEM_STR="${CYAN}${MEM_MB}MB${RESET}"

    printf "    %-16s %6b  %-35b %8b %8b\n" "$SHORT" "$CTX_STR" "$BAR" "$CPU_STR" "$MEM_STR"
  done

  echo ""

  # ── 총합 ──
  TOTAL_LINE=$(ps aux | grep -E "command claude|claude --agent" | grep -v grep | grep -v "node\|python\|bash" | awk '{cpu+=$3; mem+=$6; n++} END {printf "%d %.1f %.0f", n, cpu, mem/1024}')
  PROC_COUNT=$(echo "$TOTAL_LINE" | awk '{print $1}')
  TOTAL_CPU=$(echo "$TOTAL_LINE" | awk '{print $2}')
  TOTAL_MEM=$(echo "$TOTAL_LINE" | awk '{print $3}')

  printf "  ${BOLD}Total${RESET}  ${CYAN}${PROC_COUNT}${RESET} processes  CPU ${CYAN}${TOTAL_CPU}%%${RESET}  MEM ${CYAN}${TOTAL_MEM}MB${RESET}\n"

  # ── 대시보드 ──
  DASH_LINE=$(ps aux | grep "dashboard/server.py" | grep -v grep | head -1)
  if [ -n "$DASH_LINE" ]; then
    DASH_MEM=$(echo "$DASH_LINE" | awk '{printf "%.0f", $6/1024}')
    printf "  ${BOLD}Dashboard${RESET}  ${GREEN}running${RESET} (${DASH_MEM}MB)\n"
  fi

  echo ""
  printf "  ${DIM}Refresh: 3s${RESET}  ${YELLOW}⚠ CTX 60%%+ → auto-compact 훅 활성${RESET}\n"

  sleep 3
done
