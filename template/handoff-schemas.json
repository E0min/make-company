          }
        },
        "endpoints": {
          "type": "object[]",
          "required": true,
          "description": "API 엔드포인트 목록",
          "items": {
            "method": {
              "type": "string",
              "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
              "description": "HTTP 메서드"
            },
            "path": {
              "type": "string",
              "description": "경로 (예: '/users/:id/profile')"
            },
            "purpose": {
              "type": "string",
              "description": "이 API가 어떤 화면/기능에 사용되는지"
            },
            "requestBody": {
              "type": "object | null",
              "description": "요청 바디 스키마 (JSON 형태, null이면 바디 없음)"
            },
            "requestParams": {
              "type": "object | null",
              "description": "URL 파라미터 (예: { id: 'string (UUID)' })"
            },
            "queryParams": {
              "type": "object | null",
              "description": "쿼리스트링 파라미터 (예: { page: 'number', limit: 'number' })"
            },
            "responseSuccess": {
              "type": "object",
              "description": "성공 응답 (status code + body 스키마)",
              "properties": {
                "status": { "type": "number" },
                "body": { "type": "object" }
              }
            },
            "responseErrors": {
              "type": "object[]",
              "description": "에러 응답 목록",
              "items": {
                "status": { "type": "number", "description": "HTTP 상태 코드" },
                "code": { "type": "string", "description": "애플리케이션 에러 코드" },
                "message": { "type": "string", "description": "에러 메시지 예시" },
                "when": { "type": "string", "description": "이 에러가 발생하는 조건" }
              }
            },
            "rateLimit": {
              "type": "string | null",
              "description": "레이트 리밋 (예: '100 req/min', null이면 제한 없음)"
            }
          }
        },
        "pagination": {
          "type": "object",
          "required": false,
          "description": "페이지네이션 공통 규약",
          "properties": {
            "style": {
              "type": "string",
              "enum": ["offset", "cursor"],
              "description": "페이지네이션 방식"
            },
            "defaultLimit": {
              "type": "number",
              "description": "기본 페이지 크기"
            },
            "maxLimit": {
              "type": "number",
              "description": "최대 페이지 크기"
            },
            "responseShape": {
              "type": "string",
              "description": "페이지네이션 응답 구조 (예: '{ data: T[], meta: { total, page, limit } }')"
            }
          }
        },
        "errorFormat": {
          "type": "object",
          "required": true,
          "description": "에러 응답 공통 포맷",
          "properties": {
            "shape": {
              "type": "string",
              "description": "에러 바디 구조 (예: '{ error: { code: string, message: string, details?: object } }')"
            }
          }
        },
        "websocket": {
          "type": "object | null",
          "required": false,
          "description": "웹소켓 연결 정보 (실시간 기능이 있는 경우)",
          "properties": {
            "url": {
              "type": "string",
              "description": "웹소켓 URL"
            },
            "events": {
              "type": "object[]",
              "description": "이벤트 목록 ({ name, direction: 'server→client' | 'client→server', payload })"
            }
          }
        },
        "mockData": {
          "type": "string | null",
          "required": false,
          "description": "목 데이터 파일 경로 또는 MSW 핸들러 경로 (프론트엔드 선행 개발용)"
        }
      }
    },

