{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Virtual Company Agent Handoff Schemas",
  "description": "에이전트 간 구조화된 정보 전달을 위한 핸드오프 스키마 정의. 각 경로별로 발신자가 채워야 하는 필드와 수신자가 기대하는 데이터 형태를 명시한다.",
  "version": "1.0.0",
  "lastUpdated": "2026-04-09",

  "handoffs": {

    "pm_to_designer": {
      "id": "pm_to_designer",
      "from": "pm",
      "to": "design",
      "description": "PM이 PRD 완성 후 디자이너에게 디자인 작업에 필요한 정보만 추려서 전달",
      "fields": {
        "handoffId": {
          "type": "string",
          "required": true,
          "description": "핸드오프 고유 식별자 (예: HO-pm-design-20260409-001)"
        },
        "taskRef": {
          "type": "string",
          "required": true,
          "description": "원본 PRD 또는 태스크의 참조 ID"
        },
        "productOneLiner": {
          "type": "string",
          "required": true,
          "description": "서비스 한 줄 정의 (30자 이내)"
        },
        "persona": {
          "type": "object",
          "required": true,
          "description": "타겟 사용자 페르소나",
          "properties": {
            "name": {
              "type": "string",
              "description": "페르소나 이름 또는 유형 (예: '주니어 개발자 민수')"
            },
            "age": {
              "type": "string",
              "description": "연령대 (예: '25-35세')"
            },
            "context": {
              "type": "string",
              "description": "사용 환경과 맥락 (예: '모바일 출퇴근 중, 짧은 시간')"
            },
            "techLiteracy": {
              "type": "string",
              "enum": ["low", "medium", "high"],
              "description": "기술 이해도 수준"
            },
            "goals": {
              "type": "string[]",
              "description": "사용자가 달성하려는 핵심 목표 목록"
            }
          }
        },
        "coreUserFlows": {
          "type": "object[]",
          "required": true,
          "description": "핵심 유저플로우 (디자이너가 화면을 도출할 근거)",
          "items": {
            "flowName": {
              "type": "string",
              "description": "플로우 이름 (예: '첫 온보딩')"
            },
            "steps": {
              "type": "string[]",
              "description": "단계별 사용자 행동 (예: ['앱 실행', '소셜 로그인', '관심사 선택'])"
            },
            "coreValueMoment": {
              "type": "string",
              "description": "이 플로우에서 핵심 가치를 느끼는 순간"
            }
          }
        },
        "pages": {
          "type": "string[]",
          "required": true,
          "description": "도출된 페이지/화면 목록 (예: ['스플래시', '온보딩', '홈', '상세', '마이페이지'])"
        },
        "visualPriority": {
          "type": "object[]",
          "required": true,
          "description": "화면별 시각적 우선순위 (어떤 요소가 가장 눈에 먼저 들어와야 하는지)",
          "items": {
            "page": {
              "type": "string",
              "description": "페이지명"
            },
            "hierarchy": {
              "type": "string[]",
              "description": "시각적 우선순위 순서 (예: ['CTA 버튼', '추천 카드', '네비게이션'])"
            }
          }
        },
        "toneAndManner": {
          "type": "object",
          "required": true,
          "description": "디자인 톤앤매너 가이드",
          "properties": {
            "keywords": {
              "type": "string[]",
              "description": "톤 키워드 (예: ['전문적', '신뢰', '깔끔'])"
            },
            "references": {
              "type": "string[]",
              "description": "참고 서비스/사이트 (예: ['linear.app', 'notion.so'])"
            },
            "colorDirection": {
              "type": "string",
              "description": "색상 방향성 (예: '다크 모드 우선, 보라 단일 액센트')"
            }
          }
        },
        "platform": {
          "type": "string",
          "required": true,
          "description": "출시 플랫폼 (예: 'Web (Desktop + Mobile responsive)')"
        },
        "constraints": {
          "type": "string[]",
          "required": false,
          "description": "디자인 제약사항 (예: ['기존 디자인 시스템 따를 것', '이미지 에셋 없음, 아이콘만'])"
        },
        "nonGoals": {
          "type": "string[]",
          "required": true,
          "description": "디자인 범위에 포함하지 않는 것 (예: ['애니메이션 없음', '다크모드만'])"
        },
        "figmaBranch": {
          "type": "string",
          "enum": ["A_figma", "B_html", "unknown"],
          "required": true,
          "description": "디자인 워크플로 분기 (A: Figma 사용, B: design-guide.html, unknown: 디자이너 판단)"
        }
      }
    },

    "pm_to_frontend": {
      "id": "pm_to_frontend",
      "from": "pm",
      "to": "frontend",
      "description": "PM이 프론트엔드 엔지니어에게 구현에 필요한 기획 정보 전달",
      "fields": {
        "handoffId": {
          "type": "string",
          "required": true,
          "description": "핸드오프 고유 식별자"
        },
        "taskRef": {
          "type": "string",
          "required": true,
          "description": "원본 PRD 참조 ID"
        },
        "pages": {
          "type": "object[]",
          "required": true,
          "description": "페이지별 구현 명세",
          "items": {
            "pageName": {
              "type": "string",
              "description": "페이지 이름 (예: '홈')"
            },
            "route": {
              "type": "string",
              "description": "URL 경로 (예: '/home')"
            },
            "sections": {
              "type": "string[]",
              "description": "페이지 내 섹션 목록 (예: ['히어로', '추천 카드 그리드', 'CTA'])"
            }
          }
        },
        "userStories": {
          "type": "object[]",
          "required": true,
          "description": "유저 스토리와 수용 기준",
          "items": {
            "id": {
              "type": "string",
              "description": "스토리 ID (예: 'US-001')"
            },
            "story": {
              "type": "string",
              "description": "유저 스토리 문장 ('유저는 [목적]을 위해 [동작]을 원한다')"
            },
            "acceptanceCriteria": {
              "type": "object[]",
              "description": "Given/When/Then 형식 수용 기준",
              "items": {
                "given": { "type": "string" },
                "when": { "type": "string" },
                "then": { "type": "string" }
              }
            }
          }
        },
        "states": {
          "type": "object",
          "required": true,
          "description": "각 화면/컴포넌트의 상태 정의",
          "properties": {
            "loading": {
              "type": "string",
              "description": "로딩 상태 동작 정의"
            },
            "empty": {
              "type": "string",
              "description": "데이터 없을 때 동작 정의"
            },
            "error": {
              "type": "string",
              "description": "에러 발생 시 동작 정의"
            },
            "success": {
              "type": "string",
              "description": "정상 상태 동작 정의"
            }
          }
        },
        "edgeCases": {
          "type": "string[]",
          "required": true,
          "description": "프론트엔드에서 처리해야 할 엣지 케이스 (예: ['네트워크 끊김 시 캐시 표시', '긴 텍스트 말줄임'])"
        },
        "apiContractDraft": {
          "type": "object[]",
          "required": false,
          "description": "API 계약 초안 (백엔드 확정 전 PM이 제안하는 구조)",
          "items": {
            "endpoint": {
              "type": "string",
              "description": "엔드포인트 (예: 'GET /api/v1/recommendations')"
            },
            "purpose": {
              "type": "string",
              "description": "이 API가 어떤 화면/기능에 사용되는지"
            },
            "responseShape": {
              "type": "string",
              "description": "응답 구조 힌트 (예: '{ items: Array<{id, title, thumbnail}> }')"
            }
          }
        },
        "nonGoals": {
          "type": "string[]",
          "required": true,
          "description": "프론트엔드 구현 범위에 포함하지 않는 것"
        }
      }
    },

    "pm_to_backend": {
      "id": "pm_to_backend",
      "from": "pm",
      "to": "backend",
      "description": "PM이 백엔드 엔지니어에게 서버/API 구현에 필요한 기획 정보 전달",
      "fields": {
        "handoffId": {
          "type": "string",
          "required": true,
          "description": "핸드오프 고유 식별자"
        },
        "taskRef": {
          "type": "string",
          "required": true,
          "description": "원본 PRD 참조 ID"
        },
        "dataModelHints": {
          "type": "object[]",
          "required": true,
          "description": "데이터 모델 단서 (유저 스토리/AC에서 추출한 엔티티)",
          "items": {
            "entity": {
              "type": "string",
              "description": "엔티티 이름 (예: 'User', 'Recommendation')"
            },
            "keyAttributes": {
              "type": "string[]",
              "description": "핵심 속성 (예: ['id', 'email', 'createdAt'])"
            },
            "relationships": {
              "type": "string[]",
              "description": "관계 힌트 (예: ['User hasMany Recommendation'])"
            }
          }
        },
        "authModel": {
          "type": "object",
          "required": true,
          "description": "인증/권한 모델",
          "properties": {
            "method": {
              "type": "string",
              "description": "인증 방식 (예: 'JWT + OAuth2 소셜 로그인')"
            },
            "roles": {
              "type": "string[]",
              "description": "사용자 역할 (예: ['guest', 'user', 'admin'])"
            },
            "permissions": {
              "type": "string[]",
              "description": "역할별 주요 권한 (예: ['admin: 전체 CRUD', 'user: 본인 데이터 RU'])"
            }
          }
        },
        "externalDependencies": {
          "type": "object[]",
          "required": false,
          "description": "외부 API/서비스 의존성",
          "items": {
            "name": {
              "type": "string",
              "description": "서비스명 (예: 'OpenAI API')"
            },
            "purpose": {
              "type": "string",
              "description": "사용 목적"
            },
            "criticality": {
              "type": "string",
              "enum": ["critical", "degradable", "optional"],
              "description": "장애 시 영향도 (critical: 서비스 중단, degradable: 기능 저하, optional: 무시 가능)"
            }
          }
        },
        "performanceRequirements": {
          "type": "object",
          "required": true,
          "description": "성능 요구사항",
          "properties": {
            "responseTime": {
              "type": "string",
              "description": "API 응답 시간 목표 (예: 'p99 < 200ms')"
            },
            "throughput": {
              "type": "string",
              "description": "처리량 목표 (예: '100 RPS')"
            },
            "dataScale": {
              "type": "string",
              "description": "예상 데이터 규모 (예: '초기 1만 건, 1년 후 100만 건')"
            }
          }
        },
        "userStories": {
          "type": "object[]",
          "required": true,
          "description": "유저 스토리와 수용 기준 (API 도출 근거)",
          "items": {
            "id": { "type": "string" },
            "story": { "type": "string" },
            "acceptanceCriteria": {
              "type": "object[]",
              "items": {
                "given": { "type": "string" },
                "when": { "type": "string" },
                "then": { "type": "string" }
              }
            }
          }
        },
        "risks": {
          "type": "string[]",
          "required": true,
          "description": "백엔드 관련 리스크/가정 (예: ['외부 API 응답 지연 시 타임아웃 필요', 'DB 마이그레이션 다운타임 0'])"
        },
        "nonGoals": {
          "type": "string[]",
          "required": true,
          "description": "백엔드 구현 범위에 포함하지 않는 것 (예: ['실시간 알림은 2차', '결제 연동은 이번 제외'])"
        }
      }
    },

    "designer_to_frontend": {
      "id": "designer_to_frontend",
      "from": "design",
      "to": "frontend",
      "description": "디자이너가 프론트엔드 엔지니어에게 구현 가능한 디자인 스펙 전달",
      "fields": {
        "handoffId": {
          "type": "string",
          "required": true,
          "description": "핸드오프 고유 식별자"
        },
        "taskRef": {
          "type": "string",
          "required": true,
          "description": "원본 PRD/디자인 태스크 참조 ID"
        },
        "designGuideUrl": {
          "type": "string",
          "required": true,
          "description": "디자인 가이드 경로 (Figma URL 또는 design-guide.html 파일 경로)"
        },
        "branch": {
          "type": "string",
          "enum": ["A_figma", "B_html"],
          "required": true,
          "description": "디자인 워크플로 분기 (A: Figma, B: HTML 가이드)"
        },
        "designSystem": {
          "type": "object",
          "required": true,
          "description": "디자인 시스템 토큰 정의",
          "properties": {
            "colors": {
              "type": "object",
              "description": "색상 토큰 맵 (예: { '--accent': '#5e6ad2', '--bg-base': '#08080a' })"
            },
            "typography": {
              "type": "object",
              "description": "타이포그래피 스케일 (예: { 'text-base': '13px/20px Geist', 'text-lg': '16px/24px Geist' })"
            },
            "spacing": {
              "type": "object",
              "description": "스페이싱 토큰 (예: { '--space-2': '8px', '--space-4': '16px' })"
            },
            "radius": {
              "type": "object",
              "description": "보더 반경 (예: { '--radius-md': '6px', '--radius-lg': '8px' })"
            },
            "motion": {
              "type": "object",
              "description": "모션 토큰 (예: { '--motion-fast': '150ms', '--ease-default': 'cubic-bezier(0.16,1,0.3,1)' })"
            }
          }
        },
        "components": {
          "type": "object[]",
          "required": true,
          "description": "컴포넌트별 스펙",
          "items": {
            "name": {
              "type": "string",
              "description": "컴포넌트명 (PascalCase, 예: 'HeroSection')"
            },
            "props": {
              "type": "object",
              "description": "Props 인터페이스 (예: { title: 'string', variant: 'primary | secondary' })"
            },
            "variants": {
              "type": "string[]",
              "description": "컴포넌트 변형 (예: ['default', 'compact', 'loading'])"
            },
            "states": {
              "type": "object",
              "description": "상태별 스타일 변화 (예: { hover: 'bg-hover', active: 'bg-active', disabled: 'opacity-50' })"
            },
            "dimensions": {
              "type": "object",
              "description": "치수 (예: { width: '100%', height: '32px', padding: '0 16px' })"
            },
            "tokens": {
              "type": "string[]",
              "description": "이 컴포넌트가 사용하는 디자인 토큰 목록"
            }
          }
        },
        "pageLayouts": {
          "type": "object[]",
          "required": true,
          "description": "페이지별 레이아웃과 컴포넌트 배치",
          "items": {
            "pageName": {
              "type": "string",
              "description": "페이지명"
            },
            "layout": {
              "type": "string",
              "description": "레이아웃 구조 설명 (예: 'sidebar-240px + main-fluid, header-48px sticky')"
            },
            "componentOrder": {
              "type": "string[]",
              "description": "컴포넌트 배치 순서 (위에서 아래)"
            },
            "responsive": {
              "type": "object",
              "description": "반응형 브레이크포인트별 변화 (예: { 'mobile': 'sidebar 숨김, 단일 컬럼', 'tablet': '2컬럼 그리드' })"
            }
          }
        },
        "interactions": {
          "type": "object[]",
          "required": false,
          "description": "인터랙션/애니메이션 스펙",
          "items": {
            "trigger": {
              "type": "string",
              "description": "트리거 (예: 'hover', 'click', 'scroll-into-view')"
            },
            "target": {
              "type": "string",
              "description": "대상 컴포넌트"
            },
            "animation": {
              "type": "string",
              "description": "애니메이션 설명 (예: 'opacity 0→1, translateY 8→0, 150ms ease-default')"
            }
          }
        },
        "assets": {
          "type": "object[]",
          "required": false,
          "description": "필요한 에셋 목록",
          "items": {
            "name": {
              "type": "string",
              "description": "에셋명"
            },
            "type": {
              "type": "string",
              "enum": ["svg", "png", "icon", "font"],
              "description": "에셋 타입"
            },
            "path": {
              "type": "string",
              "description": "파일 경로 또는 다운로드 URL"
            }
          }
        },
        "accessibilityNotes": {
          "type": "string[]",
          "required": false,
          "description": "접근성 관련 메모 (예: ['모든 이미지에 alt 텍스트', 'focus ring 2px accent'])"
        }
      }
    },

    "backend_to_frontend": {
      "id": "backend_to_frontend",
      "from": "backend",
      "to": "frontend",
      "description": "백엔드가 프론트엔드에게 확정된 API 계약 전달",
      "fields": {
        "handoffId": {
          "type": "string",
          "required": true,
          "description": "핸드오프 고유 식별자"
        },
        "taskRef": {
          "type": "string",
          "required": true,
          "description": "원본 PRD 참조 ID"
        },
        "baseUrl": {
          "type": "string",
          "required": true,
          "description": "API 베이스 URL (예: 'http://localhost:3001/api/v1')"
        },
        "authScheme": {
          "type": "object",
          "required": true,
          "description": "인증 방식 (프론트엔드가 요청 시 사용할 정보)",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["bearer", "cookie", "apiKey", "none"],
              "description": "인증 타입"
            },
            "headerName": {
              "type": "string",
              "description": "헤더명 (예: 'Authorization')"
            },
            "tokenStorage": {
              "type": "string",
