# npm-specific ignore — overrides .gitignore for `npm pack`/`publish`.
# Goal: ship the prebuilt Next.js static export (template/dashboard-next-v2/out/)
# but exclude development cruft.

# Dev / source artifacts we don't ship to npm consumers
.git/
.github/
.claude/
examples/
node_modules/
template/dashboard-next-v2/node_modules/
template/dashboard-next-v2/.next/
template/dashboard-next-v2/.turbo/
template/dashboard-next-v2/AGENTS.md
template/dashboard-next-v2/CLAUDE.md

# Internal docs that aren't needed at runtime
DESIGN.md
CLAUDE.md

# OS / editor cruft
.DS_Store
*.log
*.tsbuildinfo
__pycache__/
*.pyc
.env*

# Tests
template/test/
