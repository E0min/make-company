# npm-specific ignore — overrides .gitignore for `npm pack`/`publish`.
# Goal: ship the prebuilt Next.js static export (template/dashboard-next/out/)
# but exclude development cruft.

# Dev / source artifacts we don't ship to npm consumers
.git/
.github/
.claude/
examples/
node_modules/
template/dashboard-next/node_modules/
template/dashboard-next/.next/
template/dashboard-next/.turbo/
template/dashboard-next/node_modules
template/dashboard-next/AGENTS.md
template/dashboard-next/CLAUDE.md

# Internal docs that aren't needed at runtime
DESIGN.md
CLAUDE.md

# OS / editor cruft
.DS_Store
*.log
*.tsbuildinfo
__pycache__/
*.pyc
.env*

# Tests
template/test/
